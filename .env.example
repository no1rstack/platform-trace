# Infisical project: 18f8c337-f12b-470b-a4f7-bb88cf94c679 (slug: platform-trace-zb-re)
# OSINT keys: synced from Judicium via ../judicium/scripts/sync-osint-secrets.sh
HOST=0.0.0.0
PLATFORM_TRACE_DATA_DIR=./data
DATABASE_URL=
PLATFORM_TRACE_TOKEN=
PLATFORM_PUBLIC_URL=https://trace.noirstack.com

# Keycloak (trace.noirstack.com)
PLATFORM_TRACE_AUTH_REQUIRED=1
PLATFORM_TRACE_COOKIE_SECURE=0
PLATFORM_TRACE_REQUIRED_ROLES=trace.noirstack.com
KEYCLOAK_BASE_URL=https://auth.noirstack.com
KEYCLOAK_REALM=gateway
KEYCLOAK_CLIENT_ID=platform-trace-noirstack
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=https://trace.noirstack.com/api/auth/callback
KEYCLOAK_HOME_URL=https://trace.noirstack.com

# Collectors (30s default — same cadence family as Harvest RSS / Judicium proactive pull)
COLLECTOR_INTERVAL_MS=30000
COLLECTOR_CASCADES_ENABLED=false
COLLECTOR_CASCADES_URL=http://127.0.0.1:3102
COLLECTOR_CASCADES_LEGACY_ENABLED=false
COLLECTOR_PLATFORM_HEALTH_ENABLED=false
COLLECTOR_PLATFORM_HEALTH_URL=http://127.0.0.1:3000

# Judicium OSINT workflow trace (legal_research, sanctions_screening, proactive pull)
COLLECTOR_JUDICIUM_ENABLED=false
COLLECTOR_JUDICIUM_URL=http://127.0.0.1:3002
# COLLECTOR_JUDICIUM_TOKEN=   # COLLECTION_INTERNAL_TOKEN from Harvest/Judicium Infisical

# Legislative / OSINT keys (optional here — Judicium executes searches; kept for deploy parity)
# CONGRESS_API_KEY=
