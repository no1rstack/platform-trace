{
  "name": "@noirstack/trace-client",
  "version": "0.1.0",
  "description": "Emit execution trace events to platform-trace from any Noir Stack service",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
